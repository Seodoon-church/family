{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "/_next/static/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/stories/*/",
        "destination": "/stories/_/index.html"
      },
      {
        "source": "/stories/*",
        "destination": "/stories/_/index.html"
      },
      {
        "source": "/members/*/",
        "destination": "/members/_/index.html"
      },
      {
        "source": "/members/*",
        "destination": "/members/_/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
