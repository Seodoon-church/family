rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 헬퍼 함수 ───
    // 로그인 여부
    function isAuth() {
      return request.auth != null;
    }
    // 본인 여부
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    // 해당 가족 소속 여부 (users 문서의 familyId로 확인)
    function isFamilyMember(familyId) {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }
    // 해당 가족의 ADMIN 여부
    function isFamilyAdmin(familyId) {
      return isFamilyMember(familyId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // ─── User Profiles ───
    match /users/{userId} {
      // 로그인한 사용자는 누구든 프로필 읽기 가능 (가족 가입 시 필요)
      allow read: if isAuth();
      // 본인 프로필만 쓰기 가능
      allow write: if isOwner(userId);
    }

    // ─── Families ───
    match /families/{familyId} {
      // 로그인한 사용자는 가족 정보 읽기 가능 (초대코드 검색 시 필요)
      allow read: if isAuth();
      // 새 가족 생성은 누구나 가능
      allow create: if isAuth();
      // 가족 정보 수정은 소속 멤버만
      allow update: if isFamilyMember(familyId);
      // 가족 삭제는 관리자만
      allow delete: if isFamilyAdmin(familyId);

      // ─── Members (구성원) ───
      match /members/{memberId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyAdmin(familyId);
      }

      // ─── Stories (이야기) ───
      match /stories/{storyId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        // 본인 글 수정 또는 관리자
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId) &&
          (resource.data.authorId == request.auth.uid || isFamilyAdmin(familyId));

        // ─── Comments (댓글) ───
        match /comments/{commentId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId) &&
            resource.data.authorId == request.auth.uid;
          allow delete: if isFamilyMember(familyId) &&
            (resource.data.authorId == request.auth.uid || isFamilyAdmin(familyId));
        }
      }

      // ─── Messages (채팅) ───
      match /messages/{messageId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        // 채팅 메시지는 수정/삭제 불가
        allow update, delete: if false;
      }

      // ─── Media (미디어) ───
      match /media/{mediaId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId) &&
          (resource.data.uploadedBy == request.auth.uid || isFamilyAdmin(familyId));
      }

      // ─── Events (이벤트) ───
      match /events/{eventId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyAdmin(familyId);
      }

      // ─── Relationships (관계) ───
      match /relationships/{relId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId);
      }
    }

    // ─── FCM Tokens (푸시 알림 토큰) ───
    match /fcmTokens/{tokenId} {
      // 본인 토큰만 읽기/쓰기
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
